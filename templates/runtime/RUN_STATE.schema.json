{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agentic-engineering-workflow/RUN_STATE.schema.json",
  "title": "Agentic Engineering Workflow Autonomous Run State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "package_id",
    "mode",
    "active_ticket_id",
    "active_phase",
    "last_completed_ticket_id",
    "source_lock",
    "writer_lock",
    "tickets"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "package_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "enum": [
        "full_chain",
        "single_ticket"
      ]
    },
    "active_ticket_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "active_phase": {
      "$ref": "#/$defs/phaseOrNull"
    },
    "last_completed_ticket_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_ticket_id",
        "status",
        "failure_marker"
      ],
      "properties": {
        "active_ticket_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "valid",
            "pending",
            "failed"
          ]
        },
        "failure_marker": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "writer_lock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "held_by",
        "ticket_id"
      ],
      "properties": {
        "held_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "ticket_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "tickets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ticket"
      }
    }
  },
  "$defs": {
    "phase": {
      "enum": [
        "pending",
        "source_lock_validated",
        "repository_validated",
        "plan_recorded",
        "repository_ticket_recorded",
        "implementation_writer_locked",
        "implementation_spawned",
        "implementation_completed",
        "writer_thread_closed",
        "focused_tests_passed",
        "self_review_completed",
        "independent_review_spawned",
        "independent_review_completed",
        "repair_completed_or_not_needed",
        "context_curated",
        "git_delivery_started",
        "explicit_paths_staged",
        "committed",
        "pushed",
        "head_equals_upstream_proved",
        "completed"
      ]
    },
    "phaseOrNull": {
      "anyOf": [
        {
          "$ref": "#/$defs/phase"
        },
        {
          "type": "null"
        }
      ]
    },
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "id",
        "phase",
        "completed_phases",
        "delivery"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "$ref": "#/$defs/phase"
        },
        "completed_phases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/phase"
          },
          "uniqueItems": true
        },
        "resume": {
          "type": "object",
          "additionalProperties": true
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "commit_sha",
            "pushed",
            "head_equals_upstream_proved"
          ],
          "properties": {
            "commit_sha": {
              "type": [
                "string",
                "null"
              ]
            },
            "pushed": {
              "type": "boolean"
            },
            "head_equals_upstream_proved": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
